mixin icon-share(name)
    svg(
        xmlns="http://w3.org"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
    )&attributes(attributes)
        if name === 'telegram'
            path(d="m22 2-21 8 8 3 3 9 4-7 5 5 1-19z")
        else if name === 'vk'
            path(d="M14.2 19.3c-5.5 0-8.6-3.8-8.8-10.1h2.7c.1 4.6 2.2 6.5 3.8 6.9V9.2h2.6v3.9c1.6-.2 3.2-1.9 3.8-3.9h2.5c-.4 2.5-2.2 4.2-3.5 4.9 1.3.6 3.4 2.1 4.2 5.2h-2.8c-.6-1.9-2.2-3.4-3.8-3.5v3.5h-1.5z")
        else if name === 'whatsapp'
            path(d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z")
        else if name === 'facebook'
            path(d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z")
        else if name === 'x'
            path(d="M4 4l11.733 16h4.267l-11.733 -16z")
            path(d="M4 20l6.768 -6.768m2.46 -2.46l6.772 -6.772")
        else if name === 'linkedin'
            path(d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z")
            rect(width="4" height="12" x="2" y="9")
            circle(cx="4" cy="4" r="2")
        else if name === 'copy'
            rect(width="14" height="14" x="8" y="8" rx="2" ry="2")
            path(d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2")
