mixin nav-list(currentLang, currentPage)
    - 
        var menuItems = [
            { name: 'Главная', url: '' },
            { name: 'О нас', url: 'about.html' },
            { name: 'Контакты', url: 'contacts.html' }
        ]
    ul.nav__list&attributes(attributes)
        each item in menuItems
            li.nav__item
                a(href=`/worldinplus/${currentLang}/${item.url}`
                    class=`nav__link ${currentPage === item.url ? 'nav__link--active' : ''}`
                )= item.name
mixin language-link(code, name, langPath, active = false)
    a.language__option(
        href=`/worldinplus/${langPath}/${currentPage}` 
        class=active ? "language__option--active" : ""
        data-lang=langPath
    )
        .language__icon: +icon-check
        span.language__code= code
        span.language__name= name
mixin filter-item(id, filter, name, text, modifier = 'base', isChecked = false)
    label.aside__filter
        input.aside__radio.visually-hidden(
            id=id, 
            type="radio", 
            data-filter=filter,
            name=name, 
            checked=isChecked
        )
        span.aside__btn(class=`aside__btn--${modifier}`)= text