doctype html
html(lang="ru")
    head
        meta(charset="UTF-8")
        meta(name="viewport", content="width=device-width, initial-scale=1.0")
        title Мир в плюсе
        link(rel="stylesheet", href="/worldinplus/css/reset.css")
        link(rel="stylesheet", href="/worldinplus/css/fonts.css")
        link(rel="stylesheet", href="/worldinplus/css/main.css")
        script(src="/worldinplus/js/header.js" defer)
        script(src="/worldinplus/js/hero.js" defer)
    body 
        - var currentPage = 'about.html'
        - var currentLang = 'ru'
        include mixins.pug
        include header.pug
        main.main 
            section.hero.hero--about
                .container
                    .hero__wrapper 
                        h1.hero__title Мы доказываем, что мир становится лучше
                        p.hero__text.hero__text--about «Мир в плюсе» — портал позитивных новостей, где каждая история вдохновляет, а каждый факт даёт надежду. Мы собираем доказательства того, что добро побеждает.
            section.statistics
                .container 
                    .statistics__wrapper.hero__statistics
                        .hero__item 
                            .hero__icon
                                +icon-book-open
                            h3.hero__item-title 10
                            p.hero__item-text статей  опубликованно
                        .hero__item 
                            .hero__icon
                                +icon-globe
                            h3.hero__item-title 5
                            p.hero__item-text стран охваченно
                        .hero__item 
                            .hero__icon
                                +icon-users
                            h3.hero__item-title 1000
                            p.hero__item-text читателей ежемесячно
                        .hero__item 
                            .hero__icon
                                +icon-sparkles
                            h3.hero__item-title 1
                            p.hero__item-text год с вами
            section.about
                .container
                    .about__wrapper
                        .about__top
                            .about__dash
                            h2.about__title Зачем мы существуем
                        p.about__text В эпоху информационного шума люди устали от тревожных заголовков. Мы создали пространство, где журналистика служит не страху, а надежде. Здесь вы найдёте истории о людях, которые меняют мир к лучшему, о научных прорывах, которые продлевают жизни, и о проектах, которые восстанавливают природу.
            section.principles
                .container 
                    .principles__wrapper 
                        h2.principles__title Наши принципы
                        .principles__content 
                            .principles__item 
                                .principles__top 
                                    .principles__icon
                                        +icon-shield  
                                    h3.principles__subtitle Достоверность
                                p.principles__text Мы проверяем каждый факт и публикуем только подтверждённые истории. Позитивность не означает наивность.
                            .principles__item 
                                .principles__top 
                                    .principles__icon
                                        +icon-sparkles  
                                    h3.principles__subtitle Вдохновение
                                p.principles__text Каждая публикация должна оставлять ощущение, что мир можно изменить — и это уже происходит прямо сейчас.
                            .principles__item 
                                .principles__top 
                                    .principles__icon
                                        +icon-heart  
                                    h3.principles__subtitle Доступность
                                p.principles__text Добрые новости должны быть для всех. Мы пишем просто и понятно, без лишних терминов.

            section.team 
                .container 
                    .team__wrapper 
                        .team__top
                            h2.team__title Команда
                            p.team__text Нас объединяет вера в силу хороших историй
                        .team__content 
                            .team__item 
                                .team__image 
                                    .team__bg-image 👩‍💼
                                .team__info 
                                    h3.team__name Анна Светлова
                                    p.team__job-title Главный редактор
                                    p.team__description 10 лет в журналистике. Верит, что каждая история способна изменить чью-то жизнь к лучшему.
                            .team__item 
                                .team__image 
                                    .team__bg-image 👨‍🔬
                                .team__info 
                                    h3.team__name Михаил Добров
                                    p.team__job-title Редактор науки
                                    p.team__description Физик по образованию, журналист по призванию. Переводит сложное в понятное.
                            .team__item 
                                .team__image 
                                    .team__bg-image 👩‍🎨
                                .team__info 
                                    h3.team__name Мария Надеждина
                                    p.team__job-title Редактор проектов
                                    p.team__description Находит удивительные социальные инициативы по всему миру и делится ими с читателями.
                            .team__item 
                                .team__image 
                                    .team__bg-image 👨‍💻
                                .team__info 
                                    h3.team__name Дмитрий Лучёв
                                    p.team__job-title Технический директор
                                    p.team__description Создаёт цифровую платформу, которая делает добрые новости доступными для всех.
            section.subscription
                .container 
                    .subscription__wrapper 
                        .subscription__content 
                            .subscription__image 🌟
                            h2.subscription__title Хотите получать добрые новости?
                            p.subscription__text Подпишитесь на еженедельную рассылку и читайте лучшие истории прямо в почте
                            a(href="").subscription__link 
                                +icon-mail.subscription__icon
                                | Подписаться на рассылку
                                +icon-arrow-right.subscription__icon

        include footer.pug