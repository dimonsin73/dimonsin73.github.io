doctype html
html(lang="ru")
    head
        meta(charset="UTF-8")
        meta(name="viewport", content="width=device-width, initial-scale=1.0")
        title Мир в плюсе — Позитивные новости
        link(rel="stylesheet", href="/worldinplus/css/reset.css")
        link(rel="stylesheet", href="/worldinplus/css/fonts.css")
        link(rel="stylesheet", href="/worldinplus/css/main.css")
        script(src="/worldinplus/js/header.js" defer)
    body 
        include ../../../header.pug
        main.main
            section.article 
                .container
                    .article__wrapper 
                        a(href="../../../").article__back
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="m12 19-7-7 7-7"></path>
                                <path d="M19 12H5"></path>
                            </svg>
                            | Назад к новостям
                        .article__image 
                            img(src="photo-1511671782779-c97d3d27a1d4.jpeg", alt="").article__img
                            span.article__rubric.article__rubric--story Истории
                        p.article__category Общество
                        h2.article__title Бездомный музыкант собрал средства на приют благодаря уличным концертам
                        h3.article__subtitle История Алексея, который три года жил на улице, а затем своим талантом вдохновил тысячи людей помочь другим бездомным.

        include ../../../footer.pug