header.header 
    .container
        .header__wrapper
            a(href=`/worldinplus/${currentLang}/`).logo.header__logo
                .logo__image
                    img(src="/worldinplus/images/logo.png", alt="Мир в плюсе").logo__img
                .logo__content
                    span.logo__title Мир в плюсе
                    span.logo__text Добрые новости, которые вдохновляют
            button(type="button", aria-label="Открыть меню").burger 
                +icon-burger.burger__icon.burger__icon--open(aria-hidden="true")
                +icon-close.burger__icon.burger__icon--close(aria-hidden="true")
            .menu
                nav.nav.header__nav
                    +nav-list(currentLang, currentPage)
                .header__controls 
                    .search 
                        form.search__form
                            input(type="search", placeholder="Поиск по новостям...", aria-label="Введите запрос").search__input
                        button(type="button", aria-label="Поиск").search__btn
                            +icon-magnifier.search__icon.search__icon--magnifier(aria-hidden="true")
                            +icon-close.search__icon.search__icon--close(aria-hidden="true")
                    .language 
                        button(type="button", aria-expanded="false", aria-label="Сменить язык", aria-haspopup="true").language__view
                            .language__icon 
                                +icon-globe.header__icon
                            span.language__code RU
                            span.language__name Русский 
                        .language__dropdown 
                            .language__options 
                                +language-link('RU', 'Русский', 'ru', true)
                                +language-link('BY', 'Беларуская', 'by')
                                +language-link('EN', 'English', 'en')